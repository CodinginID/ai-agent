# Copy file ini menjadi .env lalu isi nilainya
# cp .env.example .env

# Token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=ISI_TOKEN_KAMU_DI_SINI

# Konfigurasi Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Batasi akses Telegram ke user ID tertentu.
# Kosongkan saat development kalau ingin semua chat yang masuk diizinkan.
# Isi beberapa user dengan koma, contoh: ADMIN_USER_IDS=123456789,987654321
ADMIN_USER_IDS=

# Development only: true membuat semua user boleh akses.
# Jangan aktifkan ini di VPS/production.
ALLOW_UNRESTRICTED_ACCESS=false

# Direktori kerja untuk command seperti git status, ls, dan docker.
PROJECT_DIR=.

# Timeout command manual dalam detik.
COMMAND_TIMEOUT=20

# Jumlah percakapan terakhir yang dikirim ulang ke Qwen sebagai konteks.
CHAT_HISTORY_LIMIT=6

# Integrasi agent CLI via Telegram.
# Wajib isi ADMIN_USER_IDS sebelum mengaktifkan ini.
ENABLE_CODEX=false
ENABLE_CLAUDE=false
AGENT_WORKDIR=.
AGENT_TIMEOUT=180
AGENT_MAX_PROMPT_CHARS=6000

# Codex CLI
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=read-only

# Claude Code CLI
CLAUDE_BIN=claude
CLAUDE_MODEL=
CLAUDE_PERMISSION_MODE=dontAsk
CLAUDE_ALLOWED_TOOLS=Read,Grep,Glob
