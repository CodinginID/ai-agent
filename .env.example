# Copy file ini menjadi .env lalu isi nilainya
# cp .env.example .env

# Token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=ISI_TOKEN_KAMU_DI_SINI

# Konfigurasi Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Batasi akses Telegram ke user ID tertentu.
# Kosongkan saat development kalau ingin semua chat yang masuk diizinkan.
# Isi beberapa user dengan koma, contoh: ADMIN_USER_IDS=123456789,987654321
ADMIN_USER_IDS=

# Development only: true membuat semua user boleh akses.
# Jangan aktifkan ini di VPS/production.
ALLOW_UNRESTRICTED_ACCESS=false

# Direktori kerja untuk command seperti git status, ls, dan docker.
PROJECT_DIR=.
# Jika jalan via Docker dan ingin agent edit project host:
# HOST_PROJECT_DIR=/home/ali/project/codinginid/ai-agent
# PROJECT_DIR=/workspace

# Timeout command manual dalam detik.
COMMAND_TIMEOUT=20

# Jumlah percakapan terakhir yang dikirim ulang ke Qwen sebagai konteks.
CHAT_HISTORY_LIMIT=6

# Integrasi agent CLI via Telegram.
# Wajib isi ADMIN_USER_IDS sebelum mengaktifkan ini.
ENABLE_CODEX=false
ENABLE_CLAUDE=false
AGENT_WORKDIR=.
# Jika jalan via Docker dan ingin agent edit project host:
# AGENT_WORKDIR=/workspace
AGENT_TIMEOUT=180
AGENT_MAX_PROMPT_CHARS=6000

# Codex CLI
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=read-only
# Full edit mode: CODEX_SANDBOX=danger-full-access

# Claude Code CLI
CLAUDE_BIN=claude
CLAUDE_MODEL=
CLAUDE_PERMISSION_MODE=dontAsk
CLAUDE_ALLOWED_TOOLS=Read,Grep,Glob
CLAUDE_TOOLS=
# Full edit mode:
# CLAUDE_PERMISSION_MODE=bypassPermissions
# CLAUDE_ALLOWED_TOOLS=
# CLAUDE_TOOLS=default

# Multi-role agent registry.
# /agents menampilkan installed/enabled/assigned/ready untuk role ini.
AGENT_ROLE_ENGINEER=codex
AGENT_ROLE_ARCHITECT=glm
AGENT_ROLE_REVIEWER=claude

# GLM CLI placeholder untuk role architect.
# Aktifkan setelah binary/model GLM tersedia di server/container.
ENABLE_GLM=false
GLM_BIN=glm
GLM_MODEL=
GLM_ACCESS_MODE=read-only

# Terminal tools via Telegram.
# Untuk command TUI seperti btop/spf, bot mengirim snapshot/listing karena Telegram tidak punya TTY interaktif.
ENABLE_TERMINAL_TOOLS=false
TERMINAL_WORKDIR=.
# Jika jalan via Docker dan ingin terminal tools membaca project host:
# TERMINAL_WORKDIR=/workspace
TERMINAL_TIMEOUT=20
TERMINAL_ALLOWED_COMMANDS=btop,spf,fastfetch,neofetch,df,free,uptime,whoami,pwd,ls,git,docker,systemctl,journalctl,tail

# ── API Gateway (FastAPI Webhook) ────────────────────────────────────────────
# Default: bot berjalan di mode polling (tidak butuh setting ini).
# Set ENABLE_WEBHOOK=true untuk pakai webhook via FastAPI.
#
# Syarat webhook:
# 1. Server harus punya domain/IP publik dengan HTTPS (Telegram wajib HTTPS).
# 2. WEBHOOK_URL harus full URL tanpa trailing slash, contoh:
#    WEBHOOK_URL=https://bot.example.com
# 3. Arahkan reverse proxy (nginx/caddy) ke port PORT di bawah.
ENABLE_WEBHOOK=false
WEBHOOK_URL=
# Token rahasia untuk memvalidasi request dari Telegram (opsional tapi disarankan).
WEBHOOK_SECRET=
# Port yang didengarkan uvicorn saat webhook aktif.
PORT=8080

# ── Control-plane database ───────────────────────────────────────────────────
# Production: gunakan Neon PostgreSQL connection string.
# Runtime app sebaiknya pakai pooled URL dari Neon (-pooler).
# Migration sebaiknya pakai direct URL Neon agar Alembic tidak lewat PgBouncer transaction pooling.
# Jangan commit credential database asli ke repository.
DATABASE_URL=sqlite:///data/control_plane.sqlite3
DATABASE_MIGRATION_URL=sqlite:///data/control_plane.sqlite3
